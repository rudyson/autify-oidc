{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "MasterDatabase": "Data Source={serverName};Initial Catalog={initialCatalog};Integrated Security=True;"
    },
    "Jwt": {
        "Issuer": "Rudyson.Autify.Server",
        "Audience": "Rudyson.Autify.Client",
        "ExpirationMinutes": 3600,
        "Secret": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    }
}
